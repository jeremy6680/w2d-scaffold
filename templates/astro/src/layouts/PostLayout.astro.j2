{% set _date = date %}
{% raw %}
---
// src/layouts/PostLayout.astro
// Layout for individual blog posts.
{% endraw %}
// Generated by w2d-scaffold on {{ _date }}
{% raw %}

import BaseLayout from "./BaseLayout.astro";
import GiscusComments from "@/components/solidjs/GiscusComments";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags?: string[];
  image?: string;
}

const { title, description, pubDate, updatedDate, author, tags = [], image } =
  Astro.props;
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="prose mx-auto max-w-3xl px-4 py-12">
    <header>
      <h1>{title}</h1>
      <p class="text-sm text-gray-500">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString("en-US", { dateStyle: "long" })}
        </time>
        {updatedDate && (
          <span>
            · Updated{" "}
            <time datetime={updatedDate.toISOString()}>
              {updatedDate.toLocaleDateString("en-US", { dateStyle: "long" })}
            </time>
          </span>
        )}
        · {author}
      </p>
      {tags.length > 0 && (
        <ul class="flex gap-2 list-none p-0" aria-label="Tags">
          {tags.map((tag) => (
            <li>
              <a href={`/tags/${tag}`} class="tag">
                #{tag}
              </a>
            </li>
          ))}
        </ul>
      )}
    </header>

    <slot />

    <GiscusComments client:visible />
  </article>
</BaseLayout>
{% endraw %}
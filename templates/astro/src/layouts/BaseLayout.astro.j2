{% set _author = author %}
{% set _date = date %}
{% raw %}
---
// src/layouts/BaseLayout.astro
// Root layout — wraps every page with <head>, nav and footer.
{% endraw %}
// Generated by w2d-scaffold on {{ _date }}
{% raw %}

import { SEO } from "astro-seo";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SITE_LANG } from "@/consts";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = "/og-default.png",
  type = "website",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE_URL).toString();
---

<!doctype html>
<html lang={SITE_LANG} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title,
          type,
          image,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        description,
        image,
      }}
    />
  </head>

  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only">
      Skip to main content
    </a>

    <header>
      <nav aria-label="Main navigation">
        <!-- TODO: replace with your Nav component -->
        <a href="/">{SITE_TITLE}</a>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer>
{% endraw %}
      <p>&copy; {new Date().getFullYear()} {{ _author }}</p>
{% raw %}
    </footer>
  </body>
</html>
{% endraw %}
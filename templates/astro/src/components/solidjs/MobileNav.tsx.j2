{% set _date = date %}
// src/components/solidjs/MobileNav.tsx
// SolidJS island — hamburger menu for mobile navigation.
// Generated by w2d-scaffold on {{ _date }}
{% raw %}

import { createSignal } from "solid-js";
import { NAV_LINKS } from "@/consts";

export default function MobileNav() {
  const [open, setOpen] = createSignal(false);

  return (
    <nav aria-label="Mobile navigation">
      <button
        onClick={() => setOpen((v) => !v)}
        aria-expanded={open()}
        aria-controls="mobile-menu"
        aria-label={open() ? "Close menu" : "Open menu"}
        class="p-2 md:hidden"
      >
        {open() ? "✕" : "☰"}
      </button>

      {open() && (
        <ul
          id="mobile-menu"
          class="flex flex-col gap-4 py-4 md:hidden"
          role="list"
        >
          {NAV_LINKS.map((link) => (
            <li>
              
                href={link.href}
                class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded"
                onClick={() => setOpen(false)}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      )}
    </nav>
  );
}
{% endraw %}
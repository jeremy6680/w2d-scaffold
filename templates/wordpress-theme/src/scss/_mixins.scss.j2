/// Responsive breakpoint helper.
/// @param {String} $bp - Breakpoint name (sm, md, lg, xl)
@mixin respond-to($bp) {
    @if $bp == 'sm'  { @media (min-width: #{$bp-sm})  { @content; } }
    @else if $bp == 'md'  { @media (min-width: #{$bp-md})  { @content; } }
    @else if $bp == 'lg'  { @media (min-width: #{$bp-lg})  { @content; } }
    @else if $bp == 'xl'  { @media (min-width: #{$bp-xl})  { @content; } }
}

/// Visually hidden (accessible).
@mixin visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
}

/// Clearfix.
@mixin clearfix {
    &::after {
        content: '';
        display: table;
        clear: both;
    }
}
from fastapi import APIRouter, HTTPException
from pydantic import BaseModel

from app.retrieval import query as rag_query
from app.ingestion import ingest_documents

router = APIRouter()


class QueryRequest(BaseModel):
    """Request body for the /query endpoint."""

    question: str
    top_k: int = 5


class QueryResponse(BaseModel):
    """Response body for the /query endpoint."""

    answer: str


@router.post("/query", response_model=QueryResponse)
def query_endpoint(request: QueryRequest) -> QueryResponse:
    """
    Query the RAG pipeline with a natural language question.

    Args:
        request: QueryRequest containing the question and top_k parameter.

    Returns:
        QueryResponse with the generated answer.

    Raises:
        HTTPException: If the query fails.
    """
    try:
        answer = rag_query(request.question, top_k=request.top_k)
        return QueryResponse(answer=answer)
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/ingest")
def ingest_endpoint(source_dir: str = "data/raw") -> dict:
    """
    Trigger document ingestion from a source directory.

    Args:
        source_dir: Path to the folder containing raw documents.

    Returns:
        A status message confirming ingestion.

    Raises:
        HTTPException: If ingestion fails.
    """
    try:
        ingest_documents(source_dir)
        return {"status": "ok", "message": f"Documents ingested from {source_dir}"}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
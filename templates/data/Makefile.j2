# Makefile — {{ project_name_human }}
# Orchestration commands for the data pipeline.
# Generated by w2d-scaffold on {{ date }}

.PHONY: ingest transform serve clean

## Ingest raw data into the sources/ folder
ingest:
	@echo "▶ Ingesting raw data..."
	python src/ingest.py

## Run dbt transformations (bronze → silver → gold)
transform:
	@echo "▶ Running dbt transformations..."
	cd dbt && dbt run

## Serve data or launch a local exploration tool
serve:
	@echo "▶ Serving data..."
	python src/serve.py

## Clean generated artifacts and temp files
clean:
	@echo "▶ Cleaning up..."
	find . -type f -name "*.pyc" -delete
	find . -type d -name "__pycache__" -exec rm -rf {} +
	rm -rf dbt/target dbt/dbt_packages
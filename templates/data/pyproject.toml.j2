# pyproject.toml — {{ project_name_human }}
# Python project configuration and dependencies.
# Generated by w2d-scaffold on {{ date }}

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
authors = [{ name = "{{ author }}" }]
requires-python = ">=3.11"

dependencies = [
    "dbt-duckdb>=1.8",
    "duckdb>=1.0",
    "pandas>=2.0",
    "python-dotenv>=1.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "ruff>=0.4",
]

[tool.ruff]
line-length = 88
target-version = "py311"

[tool.pytest.ini_options]
testpaths = ["tests"]
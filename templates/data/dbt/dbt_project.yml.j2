# dbt_project.yml — {{ project_name_human }}
# Main dbt project configuration.
# Generated by w2d-scaffold on {{ date }}

name: "{{ project_name }}"
version: "1.0.0"
config-version: 2

profile: "{{ project_name }}"

# Directory structure
model-paths: ["models"]
analysis-paths: ["analyses"]
test-paths: ["tests"]
seed-paths: ["seeds"]
macro-paths: ["macros"]
snapshot-paths: ["snapshots"]

target-path: "target"
clean-targets:
  - "target"
  - "dbt_packages"

# Medallion architecture configuration
models:
  {{ project_name }}:
    bronze:
      +materialized: view
      +schema: bronze
    silver:
      +materialized: table
      +schema: silver
    gold:
      +materialized: table
      +schema: gold